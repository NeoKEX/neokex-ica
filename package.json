{
  "name": "ica-neokex",
  "version": "1.0.0",
  "description": "Professional Instagram Chat API library for Node.js — 124+ methods for messaging, media, real-time polling, feeds, stories, and social automation with long-running bot resilience.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "start": "npm run build && node demo.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "instagram",
    "instagram-api",
    "instagram-bot",
    "instagram-chat",
    "instagram-dm",
    "instagram-automation",
    "chat-api",
    "direct-message",
    "messaging",
    "automation",
    "bot",
    "social-media",
    "dm-automation",
    "instagram-client",
    "ica-neokex",
    "typescript"
  ],
  "author": "NeoKEX <salneowaz@gmail.com> (https://github.com/NeoKEX)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/NeoKEX/ica-neokex.git"
  },
  "bugs": {
    "url": "https://github.com/NeoKEX/ica-neokex/issues"
  },
  "homepage": "https://github.com/NeoKEX/ica-neokex#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist/",
    "src/",
    "README.md",
    "LICENSE",
    "EXAMPLES.md",
    "tsconfig.json"
  ],
  "dependencies": {
    "axios": "^1.6.2",
    "eventemitter3": "^5.0.1",
    "form-data": "^4.0.4",
    "instagram-private-api": "^1.46.1",
    "sharp": "^0.34.4"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "typescript": "^5.4.0"
  }
}
